# ============================================================
#  MẪU .env — copy thành ".env" rồi điền giá trị thật.
#  KHÔNG điền khóa thật vào file .example này.
# ============================================================

# --- 1) GEMINI ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --- 2) TELEGRAM ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- 3) PANCAKE (đa trang) ---
# Thêm trang bằng cách lặp số thứ tự: PANCAKE_PAGE_2_ID, _3_ID, ...
PANCAKE_PAGE_1_ID=
PANCAKE_PAGE_1_TOKEN=
PANCAKE_PAGE_1_CHANNEL=facebook

# Trang 3 = ZALO OA nối vào Pancake (channel=zalo). Tin THƯỜNG gửi qua Pancake (như FB).
# PANCAKE_PAGE_3_ID lấy từ Pancake (page Zalo), thường dạng "zl_<...>".
PANCAKE_PAGE_3_ID=
PANCAKE_PAGE_3_TOKEN=
PANCAKE_PAGE_3_CHANNEL=zalo

# --- 3B) ZALO OPENAPI (chỉ bật khi cần GỬI FILE/ẢNH hoặc gói cước đã có OpenAPI) ---
# Khi tắt (mặc định), bot gửi Zalo qua Pancake. Bật =1 để dùng OpenAPI (gửi PDF/video, webhook follow).
ZALO_OPENAPI_ENABLED=0
ZALO_ACCESS_TOKEN=
ZALO_REFRESH_TOKEN=
ZALO_APP_ID=
ZALO_APP_SECRET=
ZALO_OA_ID=
# --- Xác thực chữ ký webhook Zalo OA (bảo mật /zalo/webhook) ---
# OA Secret Key (KHÔNG phải App Secret) — dùng để verify chữ ký. Lấy ở Zalo OA > liên kết ứng dụng.
ZALO_OA_SECRET=
# (cũ, để tương thích — nếu chỉ có biến này thì code vẫn thử dùng làm secret verify)
ZALO_WEBHOOK_SECRET=
# Chế độ verify: off = bỏ qua | log = cảnh báo nhưng vẫn xử (BẬT THỬ vài ngày, soi log) | enforce = chặn nếu sai.
# Mặc định: off khi chưa có OA secret, log khi đã có. Chuyển 'enforce' sau khi log xác nhận chữ ký khớp.
ZALO_WEBHOOK_MODE=

# --- ZNS (tin theo SĐT, không cần follow OA) — điền template ID SAU KHI Zalo duyệt ---
ZNS_ENABLED=0
ZNS_TEMPLATE_NHACLICH=500295
# Bộ template mới soạn 10/07 (05-Ky-thuat-AI/ZNS-BO-TEMPLATE-DE-DUYET-*.md) — set ID sau khi duyệt:
ZNS_TEMPLATE_DANDO=
ZNS_TEMPLATE_KETQUA=
ZNS_TEMPLATE_XACNHAN=605793
ZNS_TEMPLATE_VOUCHER=518980

# --- 4) HỆ THỐNG ---
PORT=3000
# Token bảo vệ các endpoint /admin/* (reset-human, poke, bill-ingest). BẮT BUỘC đặt để dùng admin.
ADMIN_TOKEN=

# --- 5) RETOUCH ---
RETOUCH_MIN_IDLE_HOURS=2
RETOUCH_MAX_COUNT=2

# --- 6) CỜ TẮT BOT THEO NHÃN ---
# Telesale gắn 1 trong các nhãn này lên hội thoại Pancake (vd khi đã gọi/chốt lịch khám)
# → bot IM HẲN, không nhắn tư vấn nữa. Phân tách bằng dấu phẩy. Khớp KHÔNG dấu, không phân biệt hoa thường.
STOP_BOT_LABELS=đã đặt lịch,đã hẹn khám,đã hẹn,đã đến khám,telesale xử lý,chốt lịch,đã chốt,không gửi bot,bot dừng

# Số giờ bot "lui" sau khi telesale gõ tay / chốt lịch (mặc định 6).
HUMAN_HOLD_HOURS=6

# --- 7) ENRICH MEDi (tra hồ sơ BN cũ theo SĐT — kênh Zalo) ---
# Chọn 1 trong 2 nguồn (để TRỐNG cả hai = chưa đấu data → coi mọi khách là BN MỚI, vẫn chạy).
#  A) Sheet CÔNG KHAI: link CSV export.
MEDI_SHEET_CSV_URL=
#  B) Sheet RIÊNG TƯ: id + range + service account JSON (base64 hoặc JSON thô) ở GOOGLE_SA_JSON.
MEDI_SHEET_ID=
MEDI_SHEET_RANGE=A:Z
GOOGLE_SA_JSON=
MEDI_CACHE_TTL_MS=600000

# --- 8) CHUỖI CHẠM CA RA BILL + TÁI BILL (Zalo OA) ---
# Nguồn POS export để tự nạp ca ra bill (đấu sau — khung). Trống = nạp tay qua /admin/bill-ingest.
POS_SHEET_CSV_URL=
POS_SHEET_ID=
# Trễ tối đa cho phép (ngày) khi cron lỡ mốc — tránh sót / tránh gửi quá muộn.
BILL_GRACE_DAYS=2
REBILL_GRACE_DAYS=1.5

# --- 9) ĐÁNH THỨC BN NGỦ (tệp MEDi cũ, "xa hơn nữa") ---
WAKEUP_SLEEP_DAYS=45      # khám cách đây > X ngày & chưa lại = "ngủ"
WAKEUP_MAX_DAYS=365       # quá X ngày thì thôi (có thể đã đi nơi khác / sai số)
WAKEUP_COOLDOWN_DAYS=30   # đã nhắc thì chờ X ngày mới nhắc lại
WAKEUP_MAX_COUNT=3        # tối đa số lần đánh thức 1 BN
WAKEUP_BATCH_LIMIT=40     # trần ca TỰ gửi qua OA mỗi lần chạy (tránh đốt quota)
