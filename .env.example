# ============================================================
#  MẪU .env — copy thành ".env" rồi điền giá trị thật.
#  KHÔNG điền khóa thật vào file .example này.
# ============================================================

# --- 1) GEMINI ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --- 2) TELEGRAM ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- 3) PANCAKE (đa trang) ---
# Thêm trang bằng cách lặp số thứ tự: PANCAKE_PAGE_2_ID, _3_ID, ...
PANCAKE_PAGE_1_ID=
PANCAKE_PAGE_1_TOKEN=
PANCAKE_PAGE_1_CHANNEL=facebook

# Trang 3 = ZALO OA nối vào Pancake (channel=zalo). Tin THƯỜNG gửi qua Pancake (như FB).
# PANCAKE_PAGE_3_ID lấy từ Pancake (page Zalo), thường dạng "zl_<...>".
PANCAKE_PAGE_3_ID=
PANCAKE_PAGE_3_TOKEN=
PANCAKE_PAGE_3_CHANNEL=zalo

# USER TOKEN Pancake (API v1) — KHÔNG bị xoay vòng như token TRANG.
# Dùng cho: đọc POS/list hội thoại (pos.js, posingest.js, sevenTouch.js, rescueLead.js) VÀ
# — từ VÁ 20/07/2026 — TỰ XIN LẠI PAGE TOKEN khi Pancake trả "access_token renewed" (error 105).
# Thiếu biến này thì token trang xoay = tin gửi HỤT, phải dán tay qua POST /admin/set-token.
# Lấy ở Pancake: Cài đặt → Công cụ → API. KHÔNG commit giá trị thật.
PANCAKE_API_TOKEN=

# --- 3B) ZALO OPENAPI (chỉ bật khi cần GỬI FILE/ẢNH hoặc gói cước đã có OpenAPI) ---
# Khi tắt (mặc định), bot gửi Zalo qua Pancake. Bật =1 để dùng OpenAPI (gửi PDF/video, webhook follow).
ZALO_OPENAPI_ENABLED=0
ZALO_ACCESS_TOKEN=
ZALO_REFRESH_TOKEN=
ZALO_APP_ID=
ZALO_APP_SECRET=
ZALO_OA_ID=
# --- Xác thực chữ ký webhook Zalo OA (bảo mật /zalo/webhook) ---
# OA Secret Key (KHÔNG phải App Secret) — dùng để verify chữ ký. Lấy ở Zalo OA > liên kết ứng dụng.
ZALO_OA_SECRET=
# (cũ, để tương thích — nếu chỉ có biến này thì code vẫn thử dùng làm secret verify)
ZALO_WEBHOOK_SECRET=
# Chế độ verify: off = bỏ qua | log = cảnh báo nhưng vẫn xử (BẬT THỬ vài ngày, soi log) | enforce = chặn nếu sai.
# Mặc định: off khi chưa có OA secret, log khi đã có. Chuyển 'enforce' sau khi log xác nhận chữ ký khớp.
ZALO_WEBHOOK_MODE=

# Cửa sổ MIỄN PHÍ tin tư vấn (giây). Tin gửi trong ngần này kể từ lần khách nhắn cuối KHÔNG trừ
# quota 500. Mặc định 48h = 172800. (Chỉ đổi nếu tài liệu gói xác nhận cửa sổ khác.)
ZALO_CUA_SO_GIAY=172800

# --- ZNS (tin theo SĐT, không cần follow OA) — điền template ID SAU KHI Zalo duyệt ---
ZNS_ENABLED=0
ZNS_TEMPLATE_NHACLICH=500295
# Bộ template mới soạn 10/07 (05-Ky-thuat-AI/ZNS-BO-TEMPLATE-DE-DUYET-*.md) — set ID sau khi duyệt:
ZNS_TEMPLATE_DANDO=
ZNS_TEMPLATE_KETQUA=
ZNS_TEMPLATE_XACNHAN=605793
ZNS_TEMPLATE_VOUCHER=518980

# --- 4) HỆ THỐNG ---
PORT=3000
# Token bảo vệ các endpoint /admin/* (reset-human, poke, bill-ingest). BẮT BUỘC đặt để dùng admin.
ADMIN_TOKEN=

# --- 5) RETOUCH ---
RETOUCH_MIN_IDLE_HOURS=2
RETOUCH_MAX_COUNT=2

# --- 6) CỜ TẮT BOT THEO NHÃN ---
# Telesale gắn 1 trong các nhãn này lên hội thoại Pancake (vd khi đã gọi/chốt lịch khám)
# → bot IM HẲN, không nhắn tư vấn nữa. Phân tách bằng dấu phẩy. Khớp KHÔNG dấu, không phân biệt hoa thường.
#
# ⚠️ VÁ 20/07 — GỠ "đã đến khám" KHỎI DÒNG NÀY (trước đây file mẫu có, TRÁI với code).
# "đã đến khám" là nhãn KHÁCH ĐÃ THÀNH KHÁCH → thuộc CUSTOMER_LABELS bên dưới (chuyển mode CHĂM SÓC),
# KHÔNG phải nhãn tắt bot. Để ở đây thì MỌI bệnh nhân đã khám nhắn hỏi đều bị bot IM + đóng cờ human
# vĩnh viễn (handler.js:287) = bỏ rơi đúng nhóm khách biên cao nhất.
# LUẬT: chỉ để nhãn "TELESALE ĐANG XỬ / CẦN NGƯỜI / BOT DỪNG HẲN". Nhãn "đã mua / đã thu tiền /
# checkin / đã đến khám" → CUSTOMER_LABELS. (Code có lưới lọc trùng, nhưng đừng dựa vào lưới.)
STOP_BOT_LABELS=đã đặt lịch,đã hẹn khám,đã hẹn,telesale xử lý,chốt lịch,đã chốt,không gửi bot,bot dừng

# Nhãn "ĐÃ THÀNH KHÁCH" → bot KHÔNG im, chỉ chuyển mode CHĂM SÓC (không chào mới, không xin số).
# Nhãn nào có mặt ở CẢ 2 danh sách sẽ bị code LOẠI khỏi STOP (ưu tiên trả lời — thà thừa còn hơn im).
CUSTOMER_LABELS=đã đến khám,đã thu tiền,đã thanh toán,checkin,check-in,đã cọc,đã đặt cọc,đã mua,khách cũ,đang điều trị,chờ hàng

# Số giờ bot "lui" sau khi telesale gõ tay / chốt lịch.
# VÁ 20/07 (ca 13 hội thoại cờ human oan): hạ mặc định 6 → 2. Cờ oan khoá luôn retouch + engine chạm,
# giữ 6h chỉ làm khách bị bỏ rơi lâu hơn. Ca telesale thật đã gắn nhãn vẫn bị chặn ở STOP_BOT_LABELS.
HUMAN_HOLD_HOURS=2

# Phút giữ cờ human ở mức "TẠM NGHI" (mới thấy 1 tin page lạ, chưa chắc là telesale).
# VÁ 20/07: cờ human nay chia 2 mức (store.js markHumanTaken/isHumanActive) — tạm nghi giữ NGẮN
# bằng đúng SLA lead ≤5', thấy tin page lạ THỨ HAI mới nâng lên "đã xác nhận" và giữ HUMAN_HOLD_HOURS.
# Nhờ vậy cờ đánh OAN (echo tin chăm/ZNS/auto-reply) TỰ CHẾT sau 5', khách nhắn lượt sau là bot rep
# lại ngay, KHÔNG phải chờ engine rescue. ĐỪNG nâng quá 5 — mỗi phút im lặng là tiền quảng cáo đã trả.
HUMAN_PROBATION_MIN=5

# Phút khách chờ KHÔNG AI rep thì engine rescue coi cờ human là KẸT OAN → gỡ cờ + vớt lead.
# VÁ 20/07: hạ 20 → 5 cho khớp SLA gọi lead ≤5' (đo thật có ca chờ 23 phút vì cờ oan).
# Cron rescue 5' + RESCUE_MIN_IDLE_MIN=3 → thực tế gỡ ở ~5–8 phút. Nới lại thì đặt 8.
RESCUE_HUMAN_OVERRIDE_MIN=5

# Bao lâu mới cho engine rescue thử vớt LẠI cùng 1 (hội thoại + mốc tin khách). Đơn vị GIỜ.
# VÁ 20/07 (ca 14 hội thoại chưa đọc, khách hỏi giá tiêm 19:47–20:05 không ai rep): hạ 6 → 0.25 (15').
# Gemini 429/503 lúc cao điểm → lượt vớt chỉ ra CÂU TREO, khách chưa được trả lời gì mà ca đã bị
# khoá 6 GIỜ. Nay 15', và khi lượt vừa rồi là câu treo suy giảm thì handler còn gọi
# clearRescueAttempt() xoá dấu ngay → cron 5' sau vớt lại liền.
RESCUE_RETRY_HOURS=0.25

# VÁ 20/07 (LỖI 3 — 15× "[rescue] list qua page-token không trả mảng" trên CẢ 3 page):
# Số TRANG list v1 (user token) engine rescue quét mỗi page. Trước chỉ đọc trang 1 → 1 trang đầu bị
# comment/hội thoại cũ ăn hết slot → sót lead (đo thật có ca khách chờ 23 PHÚT).
# ⚠️ LƯỢT DEPLOY ĐẦU để 1 (kèm RESCUE_MAX_PER_RUN=3): thấy nhiều hội thoại hơn có thể vớt vọt lên
# sát trần MAX_PER_RUN ngay lượt cron đầu (guard `attempted` chỉ sống trong RAM, restart là mất).
RESCUE_LIST_PAGES=3
# Lọc type=INBOX ngay tầng API v1 (1=bật). MẶC ĐỊNH TẮT: chưa kiểm chứng v1 hiểu tham số này —
# nếu nó không hiểu mà trả RỖNG thì rescue mù NGƯỢC LẠI. Lọc client trong rescueLead.js vẫn chạy.
RESCUE_V1_TYPE_INBOX=0
# Bao lâu mới báo Telegram LẠI 1 lần cho cùng 1 page bị token xoay (chống spam 429 — cron 5' × 3 page).
PANCAKE_TOKEN_ALERT_HOURS=6

# --- VÁ 20/07 (LỖI 4 — CỬA MÙ COMMENT, ca "bot bỏ rơi 14 hội thoại" ảnh Pancake 20:05) ---
# Bot Gemini tự rep COMMENT dưới bài. MẶC ĐỊNH TẮT (=0) vì Meta Business Suite Automation
# "Bình luận để nhắn tin" đang lo phần này — bật cả hai là khách nhận TIN TRÙNG.
# CHỈ đặt =1 SAU KHI xác nhận Automation bên Meta đã tắt/hỏng (log rescue sẽ kêu
# "🔴 NGHI AUTOMATION META CHẾT" khi thấy hội thoại COMMENT khách chờ lâu không ai rep).
COMMENT_BOT_ENABLED=0
# Hội thoại COMMENT có khách nhắn cuối, chờ ≥ số phút này mà không ai rep → rescue in cảnh báo ĐỎ.
# Chỉ CẢNH BÁO ra log, KHÔNG tự gửi tin cho khách.
RESCUE_COMMENT_ALERT_MIN=15

# VÂN TAY chuỗi chăm/bot (phân tách |): tin page chứa 1 trong các mẫu này thì KHÔNG BAO GIỜ bị coi
# là "telesale gõ tay" — lưới an toàn tầng 2 phòng khi sổ echo trượt (restart/Pancake đổi text).
# Giữ HẸP: bung rộng sẽ chặn nhầm telesale thật (hậu quả nhẹ hơn: bot chạy song song người).
CARE_FINGERPRINTS=

# --- 7) ENRICH MEDi (tra hồ sơ BN cũ theo SĐT — kênh Zalo) ---
# Chọn 1 trong 2 nguồn (để TRỐNG cả hai = chưa đấu data → coi mọi khách là BN MỚI, vẫn chạy).
#  A) Sheet CÔNG KHAI: link CSV export.
MEDI_SHEET_CSV_URL=
#  B) Sheet RIÊNG TƯ: id + range + service account JSON (base64 hoặc JSON thô) ở GOOGLE_SA_JSON.
MEDI_SHEET_ID=
MEDI_SHEET_RANGE=A:Z
GOOGLE_SA_JSON=
MEDI_CACHE_TTL_MS=600000

# --- 8) CHUỖI CHẠM CA RA BILL + TÁI BILL (Zalo OA) ---
# Nguồn POS export để tự nạp ca ra bill (đấu sau — khung). Trống = nạp tay qua /admin/bill-ingest.
POS_SHEET_CSV_URL=
POS_SHEET_ID=
# Trễ tối đa cho phép (ngày) khi cron lỡ mốc — tránh sót / tránh gửi quá muộn.
BILL_GRACE_DAYS=2
REBILL_GRACE_DAYS=1.5

# --- 9) ĐÁNH THỨC BN NGỦ (tệp MEDi cũ, "xa hơn nữa") ---
WAKEUP_SLEEP_DAYS=45      # khám cách đây > X ngày & chưa lại = "ngủ"
WAKEUP_MAX_DAYS=365       # quá X ngày thì thôi (có thể đã đi nơi khác / sai số)
WAKEUP_COOLDOWN_DAYS=30   # đã nhắc thì chờ X ngày mới nhắc lại
WAKEUP_MAX_COUNT=3        # tối đa số lần đánh thức 1 BN
WAKEUP_BATCH_LIMIT=40     # trần ca TỰ gửi qua OA mỗi lần chạy (tránh đốt quota)

# --- 10) VỆ SĨ HỘP THƯ (canh account ngoại/ảo/phá hoại page Dr Nhật Trình 957014354156110) ---
# Token FB user (quyền pages_manage_metadata + pages_manage_engagement + pages_read_user_content).
# TRỐNG = bot chạy ở chế độ CHỈ-ĐỀ-XUẤT (chấm + báo Telegram, KHÔNG chặn/CAPI). Anh Trình cấp.
VESI_FB_TOKEN=
# Chat id group «Hiệp Lợi CEO Giao Ban» (KHÁC TELEGRAM_CHAT_ID = group telesale). Dùng token TELEGRAM_BOT_TOKEN.
VESI_TG_CHAT=-5473468426
# 1 (hoặc trống) = CHỈ đề-xuất + báo; 0 = THỰC chặn/ẩn/CAPI (bật sau khi anh Trình gật + tắt launchd Mac).
VESI_DRY=1
# id dataset CAPI Business Messaging (để trống tới khi tạo xong; cũng có thể nạp qua kv vesi:dataset-id).
VESI_DATASET=

# ⛔ CẦU DAO: tự lấy page token mới khi Pancake xoay token (generate_page_access_token).
# MẶC ĐỊNH TẮT (0). Lệnh này XOAY token — token cũ chết ngay. 20/07 một agent tự gọi đã
# xoay token production. Chỉ bật =1 sau khi anh Trình đã thử tay 1 lần và xác nhận schema đúng.
PANCAKE_AUTO_REFRESH=0
