# ============================================================
#  MẪU .env — copy thành ".env" rồi điền giá trị thật.
#  KHÔNG điền khóa thật vào file .example này.
# ============================================================

# --- 1) GEMINI ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --- 2) TELEGRAM ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- 3) PANCAKE (đa trang) ---
# Thêm trang bằng cách lặp số thứ tự: PANCAKE_PAGE_2_ID, _3_ID, ...
PANCAKE_PAGE_1_ID=
PANCAKE_PAGE_1_TOKEN=
PANCAKE_PAGE_1_CHANNEL=facebook

# --- 4) HỆ THỐNG ---
PORT=3000

# --- 5) RETOUCH ---
RETOUCH_MIN_IDLE_HOURS=2
RETOUCH_MAX_COUNT=2
